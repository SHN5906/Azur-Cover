# Resend — formulaire de contact
# 1) Crée un compte sur https://resend.com
# 2) Copie ta clé API ici : RESEND_API_KEY=re_...
# 3) (Prod) Vérifie un domaine dans Resend et utilise une adresse de ton domaine en FROM :
#    RESEND_FROM="Azur Cover <contact@azur-cover.com>"
# 4) Sur Vercel : Project → Settings → Environment Variables, copier ces variables
RESEND_API_KEY=
RESEND_FROM="Azur Cover <onboarding@resend.dev>"
RESEND_TO="contact@azur-cover.com"

# Neon Postgres — auto-provisionné par `vercel integration add neon`
DATABASE_URL=

# Vercel Blob — auto-provisionné par `vercel blob create-store ... --access public`
BLOB_READ_WRITE_TOKEN=

# Auth.js — secret signé pour les sessions (openssl rand -base64 32)
AUTH_SECRET=

# Email unique autorisé à se connecter à /admin
ADMIN_EMAIL=

# Mot de passe admin — requis pour la connexion à /admin.
# Utilise une valeur longue et aléatoire (≥ 24 caractères) : openssl rand -base64 24
ADMIN_PASSWORD=

# Upstash Redis — rate-limiting global (Vercel Marketplace → Upstash).
# Optionnel en dev : sans ces variables, le rate-limit retombe sur un
# compteur en mémoire (par instance). Recommandé en production.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
